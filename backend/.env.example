# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=5000
NODE_ENV=development

# ============================================
# JWT AUTHENTICATION
# ============================================

# CHANGE THIS IN PRODUCTION! Use: openssl rand -base64 32
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=7d

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Choose one:
# SQLite (development)
DATABASE_URL="file:./data/dev.db"

# MySQL (production)
# DATABASE_URL="mysql://username:password@localhost:3306/snappay"

# PostgreSQL (production)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/snappay"

# ============================================
# PRISMA ENGINE CONFIGURATION (ARM64/Windows)
# ============================================

# Uncomment if needed (e.g., Windows ARM64)
# PRISMA_CLIENT_ENGINE_TYPE=wasm
# PRISMA_QUERY_ENGINE_TYPE=wasm

# ============================================
# FRONTEND CONFIGURATION
# ============================================

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================

# REDIS_URL="redis://localhost:6379"

# ============================================
# SMS / OTP CONFIGURATION
# ============================================

# Twilio (for production SMS)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_DIR=uploads

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ============================================
# COOKIE SECURITY
# ============================================

COOKIE_SECURE=false  # Set to true in production with HTTPS
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=debug
LOG_TO_FILE=false